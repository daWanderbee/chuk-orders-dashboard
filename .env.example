# WooCommerce REST API credentials (chuk.in/wp-json/wc/v3)
# Set these in Vercel → Project → Settings → Environment Variables.
WC_USER=ck_xxxxxxxxxxxxxxxxxxxxxxxx
WC_APP_KEY=cs_xxxxxxxxxxxxxxxxxxxxxxxx

# Dashboard password gate. Leave unset to make the dashboard fully open.
APP_PASSWORD=changeme

# WooCommerce PDF-invoice plugin download URL. {id} is replaced with the order
# id. Proxied server-side so the access_key never reaches the browser.
# e.g. https://chuk.in/?page=wpo_wcpdf&action=generate_wpo_wcpdf&document_type=invoice&order_ids={id}&access_key=XXXX
INVOICE_URL_TEMPLATE=
