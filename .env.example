# WooCommerce REST API credentials (chuk.in/wp-json/wc/v3)
# Set these in Vercel → Project → Settings → Environment Variables.
WC_USER=ck_xxxxxxxxxxxxxxxxxxxxxxxx
WC_APP_KEY=cs_xxxxxxxxxxxxxxxxxxxxxxxx

# Dashboard password gate. Leave unset to make the dashboard fully open.
APP_PASSWORD=changeme

# Invoice download (APIFW plugin). Its PDF endpoint requires a logged-in
# WordPress session with manage_woocommerce — there is no access_key or REST
# route. The server logs in with these creds and reuses the session cookie.
# Use a dedicated WP user with the Shop Manager role (not your personal admin).
WP_BASE=https://chuk.in
WP_LOGIN_USER=
WP_LOGIN_PASS=
